SET SYSMENU TO
SET SYSMENU AUTOMATIC

DEFINE PAD _msm_file OF _MSYSMENU PROMPT "\<Archivo" COLOR SCHEME 3 ;
	NEGOTIATE  LEFT, NONE ;
	KEY ALT+F, "" ;
	MESSAGE "Opciones de administración, y salida de la aplicaciňn."
DEFINE PAD _msm_edit OF _MSYSMENU PROMPT "\<Modificar" COLOR SCHEME 3 ;
	KEY ALT+E, "" ;
	MESSAGE "Editar texto o selección actual"
DEFINE PAD _3p20rhuk5 OF _MSYSMENU PROMPT "\<Administración" COLOR SCHEME 3 ;
	KEY ALT+A, ""
DEFINE PAD _3p20rhuk6 OF _MSYSMENU PROMPT "\<Reportes" COLOR SCHEME 3 ;
	KEY ALT+R, ""
DEFINE PAD _3p20rhuka OF _MSYSMENU PROMPT "Consultas" COLOR SCHEME 3 ;
	KEY ALT+C, ""
DEFINE PAD _3p20rhukb OF _MSYSMENU PROMPT "\<Navegar" COLOR SCHEME 3 ;
	KEY ALT+N, "ALT+N" ;
	MESSAGE "Navegar através de los registros disponibles en la forma"
DEFINE PAD _msm_windo OF _MSYSMENU PROMPT "\<Ventana" COLOR SCHEME 3 ;
	NEGOTIATE  RIGHT, NONE ;
	KEY ALT+W, "" ;
	MESSAGE "Manejo de Ventanas"
DEFINE PAD _msm_systm OF _MSYSMENU PROMPT "A\<yuda" COLOR SCHEME 3 ;
	KEY ALT+H, "" ;
	MESSAGE "Opciones de despliegue de ayuda"
ON PAD _msm_file OF _MSYSMENU ACTIVATE POPUP file
ON PAD _msm_edit OF _MSYSMENU ACTIVATE POPUP _medit
ON PAD _3p20rhuk5 OF _MSYSMENU ACTIVATE POPUP administra
ON PAD _3p20rhuk6 OF _MSYSMENU ACTIVATE POPUP reportes
ON PAD _3p20rhuka OF _MSYSMENU ACTIVATE POPUP consultas
ON PAD _3p20rhukb OF _MSYSMENU ACTIVATE POPUP navigate
ON PAD _msm_windo OF _MSYSMENU ACTIVATE POPUP window
ON PAD _msm_systm OF _MSYSMENU ACTIVATE POPUP _msystem

DEFINE POPUP file MARGIN RELATIVE SHADOW COLOR SCHEME 4
DEFINE BAR 1 OF file PROMPT "\<Guardar" ;
	KEY CTRL+S, "Ctrl+S" ;
	SKIP FOR NOT m.goStateManager.GetValue('Form Edit Save') ;
	MESSAGE "Guardar cambios hechos a la forma o archivo actual ."
DEFINE BAR 2 OF file PROMPT "Recuper\<ar" ;
	SKIP FOR NOT m.goStateManager.GetValue('Form Edit Cancel') ;
	MESSAGE "Descartar los cambios hechos a la forma o archivo actual y recuperar la última versión."
DEFINE BAR 3 OF file PROMPT "\-"
DEFINE BAR 4 OF file PROMPT "Modifcar \<Registro..." ;
	SKIP FOR NOT 'CMREGEDT.VCX' $ SET('CLASSLIB') ;
	MESSAGE "Modificar ambiente y preferencias en el registro de la aplicación."
DEFINE BAR 5 OF file PROMPT "Modificar Cuentas de \<Usuario..." ;
	SKIP FOR NOT 'CMSECURE.VCX' $ SET('CLASSLIB') ;
	MESSAGE "Modificar información de seguridad de la aplicación."
DEFINE BAR 6 OF file PROMPT "Cam\<biar Contraseńa" ;
	SKIP FOR NOT 'CMSECURE.VCX' $ SET('CLASSLIB') ;
	MESSAGE "Cambiar la contraseńa de entrada a su aplicación."
DEFINE BAR 7 OF file PROMPT "\<Eventos de la aplicación..." ;
	SKIP FOR NOT 'CMSECURE.VCX' $ SET('CLASSLIB') ;
	MESSAGE "Ver el contenido de los eventos de la aplicación."
DEFINE BAR 8 OF file PROMPT "\-"
DEFINE BAR 9 OF file PROMPT "\<Ver Barra de Herramientas..." ;
	SKIP FOR EMPTY(m.goStateManager.aToolbars[1, 1]) ;
	MESSAGE "Abrir y cerrar barra de herramientas."
DEFINE BAR 10 OF file PROMPT "\-"
DEFINE BAR _mfi_pgset OF file PROMPT "\<Configuración de \<Página..." ;
	MESSAGE "Changes the page layout and printer settings"
DEFINE BAR 12 OF file PROMPT "Vista Pre\<liminar" ;
	SKIP FOR NOT m.goStateManager.GetValue('Form Report Preview') ;
	MESSAGE "Muestra las páginas completas tal como van a ser impresas."
DEFINE BAR 13 OF file PROMPT "\<Imprimir..." ;
	KEY CTRL+P, "Ctrl+P" ;
	SKIP FOR NOT m.goStateManager.GetValue('Form Report') ;
	MESSAGE "Imprimir un archivo de texto, reporte, o etiqueta."
DEFINE BAR 14 OF file PROMPT "\-"
DEFINE BAR 15 OF file PROMPT "\<Salir" ;
	KEY CTRL+F12, "Ctrl+F12" ;
	MESSAGE "Salir de la aplicación."
ON SELECTION BAR 1 OF file m.goStateManager.Execute('Form Edit Save')
ON SELECTION BAR 2 OF file m.goStateManager.Execute('Form Edit Cancel')
ON SELECTION BAR 4 OF file m.goStateManager.OpenForm('frmRegistryEditor')
ON SELECTION BAR 5 OF file m.goStateManager.OpenForm('frmAccountEditor')
ON SELECTION BAR 6 OF file m.goStateManager.OpenModalForm('frmSetLogonPassword')
ON SELECTION BAR 7 OF file m.goStateManager.OpenForm('frmEventViewer')
ON SELECTION BAR 9 OF file m.goStateManager.OpenForm('frmViewToolbars')
ON SELECTION BAR 12 OF file m.goStateManager.Execute('Form Report Preview', .T.)
ON SELECTION BAR 13 OF file m.goStateManager.Execute('Form Report')
ON SELECTION BAR 15 OF file m.goApp.Shutdown(.T.)

DEFINE POPUP _medit MARGIN RELATIVE SHADOW COLOR SCHEME 4
DEFINE BAR _med_undo OF _medit PROMPT "\<Deshacer" ;
	KEY CTRL+Z, "Ctrl+Z" ;
	MESSAGE "Deshacer la última acción."
DEFINE BAR _med_redo OF _medit PROMPT "\<Rehacer" ;
	KEY CTRL+R, "Ctrl+R" ;
	MESSAGE "Repite la última acción."
DEFINE BAR _med_sp100 OF _medit PROMPT "\-"
DEFINE BAR _med_cut OF _medit PROMPT "Cortar" ;
	KEY CTRL+X, "Ctrl+X" ;
	MESSAGE "Quitar la selección actual y colocarla en el portapapeles."
DEFINE BAR _med_copy OF _medit PROMPT "\<Copiar" ;
	KEY CTRL+C, "Ctrl+C" ;
	MESSAGE "Copia la selección actual al portapapeles"
DEFINE BAR _med_paste OF _medit PROMPT "\<Pegar" ;
	KEY CTRL+V, "Ctrl+V" ;
	MESSAGE "Pega el contenido del portapapeles"
DEFINE BAR _med_sp200 OF _medit PROMPT "\-"
DEFINE BAR _med_slcta OF _medit PROMPT "Seleccionar todo" ;
	KEY CTRL+A, "Ctrl+A" ;
	MESSAGE "Selecciona todo el texto o elementos en el campo actual"

DEFINE POPUP administra MARGIN RELATIVE SHADOW COLOR SCHEME 4
DEFINE BAR 1 OF administra PROMPT "Series"
DEFINE BAR 2 OF administra PROMPT "Cajas"
ON SELECTION BAR 1 OF administra m.goStateManager.OpenForm('source\frm_series.scx')
ON SELECTION BAR 2 OF administra m.goStateManager.OpenForm('source\frm_cajas.scx')

