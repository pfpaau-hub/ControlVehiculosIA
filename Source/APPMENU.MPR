DEFINE POPUP consultas MARGIN RELATIVE SHADOW COLOR SCHEME 4
DEFINE BAR 1 OF consultas PROMPT "Servicios"
ON SELECTION BAR 1 OF consultas m.goStateManager.OpenForm('source\frm_consulta_servicios.scx')

DEFINE POPUP navigate MARGIN RELATIVE SHADOW COLOR SCHEME 4
DEFINE BAR 1 OF navigate PROMPT "Primero" ;
	SKIP FOR NOT m.goStateManager.GetValue('Form Nav First') ;
	MESSAGE "Ir al primer registro"
DEFINE BAR 2 OF navigate PROMPT "\<Anterior" ;
	KEY PGUP, "Pgup" ;
	SKIP FOR NOT m.goStateManager.GetValue('Form Nav Prior') ;
	MESSAGE "Saltar hacia el registro anterior"
DEFINE BAR 3 OF navigate PROMPT "\<Siguiente" ;
	KEY PGDN, "Pgdn" ;
	SKIP FOR NOT m.goStateManager.GetValue('Form Nav Next') ;
	MESSAGE "Saltar al siguiente registro"
DEFINE BAR 4 OF navigate PROMPT "Último" ;
	SKIP FOR NOT m.goStateManager.GetValue('Form Nav Last') ;
	MESSAGE "Ir al primer registro"
DEFINE BAR 5 OF navigate PROMPT "\-"
DEFINE BAR 6 OF navigate PROMPT "\<Buscar" ;
	KEY CTRL+F, "Ctrl+F" ;
	SKIP FOR NOT m.goStateManager.GetValue('Form Find') ;
	MESSAGE "Buscar un registro específico"
DEFINE BAR 7 OF navigate PROMPT "\<Listar" ;
	SKIP FOR NOT m.goStateManager.GetValue('Form List') ;
	MESSAGE "Lista todos los registros disponibles"
DEFINE BAR 8 OF navigate PROMPT "\-"
DEFINE BAR 9 OF navigate PROMPT "Agregar  nuevo" ;
	KEY CTRL+N, "Ctrl+N" ;
	SKIP FOR NOT m.goStateManager.GetValue('Form New') ;
	MESSAGE "Agregar un nuevo registro a la forma"
DEFINE BAR 10 OF navigate PROMPT "\<Eliminar" ;
	SKIP FOR NOT m.goStateManager.GetValue('Form Delete') ;
	MESSAGE "Borrar el registro actual y sus correspondientes hijos"
ON SELECTION BAR 1 OF navigate m.goStateManager.Execute('Form Nav First')
ON SELECTION BAR 2 OF navigate m.goStateManager.Execute('Form Nav Prior')
ON SELECTION BAR 3 OF navigate m.goStateManager.Execute('Form Nav Next')
ON SELECTION BAR 4 OF navigate m.goStateManager.Execute('Form Nav Last')
ON SELECTION BAR 6 OF navigate m.goStateManager.Execute('Form Find')
ON SELECTION BAR 7 OF navigate m.goStateManager.Execute('Form List')
ON SELECTION BAR 9 OF navigate m.goStateManager.Execute('Form New')
ON SELECTION BAR 10 OF navigate m.goStateManager.Execute('Form Delete')

DEFINE POPUP window MARGIN RELATIVE SHADOW COLOR SCHEME 4
DEFINE BAR 1 OF window PROMPT "\<Cerrar" ;
	SKIP FOR NOT m.goStateManager.GetValue('Form Close') ;
	MESSAGE "Cerrar la ventana actual"
DEFINE BAR _mwi_rotat OF window PROMPT "Ciclo" ;
	KEY CTRL+F1, "Ctrl+F1" ;
	MESSAGE "Revisar las ventanas abiertas"
ON SELECTION BAR 1 OF window m.goStateManager.Execute('Form Close')

DEFINE POPUP _msystem MARGIN RELATIVE SHADOW COLOR SCHEME 4
DEFINE BAR _mst_hpsch OF _msystem PROMPT "Temas..." ;
	KEY F1, "F1" ;
	MESSAGE "Encuentra temas de ayuda sobre las palabras introducidas"
DEFINE BAR _mst_sp200 OF _msystem PROMPT "\-"
DEFINE BAR 3 OF _msystem PROMPT "\<Acerca de..." ;
	MESSAGE "Muestra información de la versión y Derechos de Autor de esta aplicación"
ON SELECTION BAR 3 OF _msystem m.goStateManager.OpenModalForm('frmAboutApplication')


