{
  "ConnectionStrings": {
    "DefaultConnection": "#{DB_CONNECTION_STRING}#"
  },
  "Jwt": {
    "Key":           "#{JWT_SECRET_KEY}#",
    "Issuer":        "ControlVehiculosAPI",
    "Audience":      "ControlVehiculosClient",
    "ExpiryMinutes": 480
  },
  "Cors": {
    "AllowedOrigins": [ "#{FRONTEND_URL}#" ]
  },
  "Logging": {
    "LogLevel": {
      "Default":              "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
